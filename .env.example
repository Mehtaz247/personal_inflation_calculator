# Optional: enables AI-generated explanation via Gemini. Without this, a
# deterministic template explanation is returned instead. The math never
# depends on the LLM.
GEMINI_API_KEY=

# Optional failover key. If GEMINI_API_KEY fails (quota, auth, persistent
# 503), the server retries the same request with this key.
GEMINI_API_KEY_2=

# Optional: forwarded to the MoSPI eSankhyiki CPI API as both an `api-key`
# header and `apikey` query param. Leave blank if the endpoint is open.
MOSPI_API_KEY=
