# Primary key: enables AI-generated explanation via Gemini. Without this, a
# deterministic template explanation is returned instead. The math never
# depends on the LLM.
GEMINI_API_KEY_2=

# Optional failover key. If GEMINI_API_KEY_2 fails (quota, auth, persistent
# 503), the server retries the same request with this key.
GEMINI_API_KEY=
